---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const allPosts: CollectionEntry<'bitacora'>[] = await getCollection('bitacora');
// Ordenamos por fecha de forma descendente y tomamos las últimas 2
const latestPosts = allPosts
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())
  .slice(0, 2);
---

<section id="bitacora" class="bitacora-preview">
  <div class="container-width">
    <div class="section-header">
      <span class="pre-title">LO QUE PASA EN EL TALLER</span>
      <h2>BITÁCORA DE ACTIVIDADES</h2>
    </div>

    {latestPosts.length > 0 ? (
      <div class="preview-wrapper">
        <div class="posts-grid">
          {latestPosts.map(post => (
            <div class="preview-card">
              <div class="preview-image">
                <img src={post.data.image} alt={post.data.title} />
              </div>
              <div class="preview-info">
                <span class="mes-tag">{post.data.mes}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <div class="actions">
                  <a href={`/bitacora/${post.slug}`} class="btn-primary">LEER BITÁCORA COMPLETA</a>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="archive-action">
          <a href="/bitacora" class="btn-secondary">VER MESES ANTERIORES</a>
        </div>
      </div>
    ) : (
      <div class="no-posts">
        <p>Próximamente compartiremos los avances de las clases dirigidas por <strong>Ana Chalabe</strong> y <strong>Florencia Piazza</strong>.</p>
      </div>
    )}
  </div>
</section>

<style>
  /* --- CONTENEDOR PRINCIPAL --- */
  .bitacora-preview { 
    padding: 10rem 0; 
    background-color: #8b1d20 !important; 
    position: relative; 
    display: block;
    width: 100%;
    transition: none !important; 
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  
  /* --- MARGENES COHERENTES CON LA WEB --- */
  .container-width {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 5%;
    position: relative;
    z-index: 2;
  }

  .section-header { margin-bottom: 4rem; text-align: left; }
  .pre-title { color: white; font-weight: 900; letter-spacing: 4px; font-size: 0.8rem; opacity: 0.8; text-transform: uppercase; }
  .section-header h2 { font-size: 3.5rem; font-weight: 900; text-transform: uppercase; margin-top: 0.5rem; color: white; line-height: 1; }

  /* --- GRILLA SIMÉTRICA DE 2 NOTICIAS --- */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    width: 100%;
  }

  /* --- TARJETA DE ADELANTO EN FORMATO VERTICAL --- */
  .preview-card { 
    display: flex;
    flex-direction: column;
    background: #111; 
    box-shadow: 0 30px 60px rgba(0,0,0,0.4);
    overflow: hidden;
  }

  .preview-image { width: 100%; height: 280px; overflow: hidden; }
  
  /* --- BLINDAJE DE IMAGEN EN PREVIEW --- */
  .preview-image img { 
    width: 100%; 
    height: 100%; 
    object-fit: cover; 
    opacity: 0.9; 
    user-select: none !important;
    -webkit-user-drag: none !important;
    -webkit-touch-callout: none !important;
    pointer-events: none; /* Anula clics, arrastres y pulsaciones largas en la imagen */
  }

  .preview-info { padding: 3rem 2.5rem; display: flex; flex-direction: column; flex-grow: 1; }
  .mes-tag { color: #d83135; font-weight: 800; letter-spacing: 2px; font-size: 0.7rem; margin-bottom: 1rem; text-transform: uppercase; }
  .preview-info h3 { font-size: 2rem; font-weight: 900; margin-bottom: 1rem; color: white; line-height: 1.2; text-transform: uppercase; }
  .preview-info p { color: #ccc; line-height: 1.6; font-size: 1.05rem; margin-bottom: 2rem; flex-grow: 1; }

  /* --- BOTONES Y ACCIONES --- */
  .actions { display: flex; width: 100%; }
  
  .btn-primary { 
    background: #d83135; 
    color: white; 
    padding: 1rem 2rem; 
    text-decoration: none; 
    font-weight: 900; 
    font-size: 0.8rem; 
    transition: 0.3s ease; 
    text-transform: uppercase;
    letter-spacing: 1px;
    text-align: center;
    width: 100%; 
    box-sizing: border-box;
  }
  .btn-primary:hover { background: white; color: #d83135; }
  
  /* CONTENEDOR DEL ENLACE AL HISTORIAL HISTÓRICO */
  .archive-action {
    margin-top: 4rem;
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .btn-secondary { 
    color: #eee; 
    text-decoration: none; 
    font-weight: 900; 
    font-size: 0.85rem; 
    border-bottom: 2px solid #ffffff; 
    padding-bottom: 4px;
    text-transform: uppercase;
    transition: 0.3s ease; 
    letter-spacing: 1px;
  }
  .btn-secondary:hover { color: #111; background-color: white; border-color: white; padding: 4px 10px; }

  .no-posts { text-align: center; padding: 4rem; color: white; background: rgba(0,0,0,0.2); }

  /* --- AJUSTES RESPONSIVE --- */
  @media (max-width: 1024px) {
    .bitacora-preview { padding: 6rem 0; }
    .posts-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .section-header h2 { font-size: 2.5rem; }
    .preview-info { padding: 2.5rem 2rem; }
    .preview-info h3 { font-size: 1.8rem; }
  }
</style>