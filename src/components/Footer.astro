---
// Datos de contacto
const contacto = {
  direccion: "Bartolomé Mitre 764, A4400 Salta",
  colegio: "Colegio Belgrano",
  whatsapp: "+54387XXXXXXX", 
  instagram: "https://instagram.com/tu_cuenta",
  horarios: "Atención: Lunes a Viernes - 14:00 a 18:00 hs"
};
---

<footer class="footer-section">
  <div class="footer-container">
    <div class="contact-grid">
      
      {/* BLOQUE 1: MAPA ESTÁNDAR (Etiqueta por fuera usando Grid) */}
      <div class="contact-card map-box">
        <div class="map-label">
          <span class="status-tag">UBICACIÓN TALLER</span>
        </div>
        <div class="map-iframe-wrapper">
          <iframe 
            src="https://maps.google.com/maps?q=Colegio+Belgrano+Salta+Bartolome+Mitre+764&t=&z=15&ie=UTF8&iwloc=&output=embed" 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
      </div>

      {/* BLOQUE 2: INFO Y ACCESO DIRECTO */}
      <div class="contact-card info-box">
        <div class="info-content">
          <span class="label">COLEGIO BELGRANO</span>
          <h3>Contáctanos</h3>
          <p class="address-text">{contacto.direccion}</p>
          
          <div class="divider"></div>
          
          <p class="summary-text">Espacio exclusivo para la comunidad educativa del colegio. Consultas sobre inscripciones y niveles por canales oficiales.</p>
          
          <p class="horarios-tag">{contacto.horarios}</p>
        </div>
        
        <div class="social-links">
          <a href={`https://wa.me/${contacto.whatsapp}`} class="social-btn wa" target="_blank">
            <span>WHATSAPP DIRECTO</span>
          </a>
          <a href={contacto.instagram} class="social-btn ig" target="_blank">
            <span>INSTAGRAM OFICIAL</span>
          </a>
        </div>
      </div>

    </div>

    <div class="footer-bottom">
      <p>© {new Date().getFullYear()} Taller de Robótica - Colegio Belgrano Salta</p>
    </div>
  </div>
</footer>

<style>
  .footer-section {
    background-color: #121212;
    padding: 80px 0 20px;
    color: white;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 5%;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: 20px;
    margin-bottom: 60px;
  }

  .contact-card {
    background: #1e1e1e; /* Gris Industrial */
    display: flex;
    flex-direction: column;
    min-height: 450px;
    border: 1px solid rgba(255,255,255,0.05);
  }

  /* --- MAPA Y ETIQUETA VERTICAL (GRID) --- */
  .map-box { 
    display: grid;
    grid-template-columns: auto 1fr; /* Columna 1 ajustada al texto, Columna 2 toma el resto */
    padding: 15px; 
    gap: 15px; 
  }
  
  .map-label {
    position: relative !important; /* Mata cualquier posición flotante vieja */
    top: 0 !important;
    left: 0 !important;
    display: flex;
    align-items: flex-start; 
  }

  .status-tag {
    background: #d83135;
    color: white;
    padding: 20px 8px; 
    font-weight: 900;
    font-size: 0.75rem;
    letter-spacing: 3px;
    white-space: nowrap; /* Evita que la palabra se rompa en dos líneas */
    
    /* TEXTO VERTICAL */
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  .map-iframe-wrapper {
    width: 100%;
    height: 100%;
    background: #252525;
    min-height: 350px; /* Asegura que el mapa no colapse */
  }

  /* --- INFO BOX --- */
  .info-box {
    padding: 40px;
    justify-content: space-between;
  }

  .label {
    color: #d83135;
    font-weight: 900;
    font-size: 0.7rem;
    letter-spacing: 2px;
    margin-bottom: 10px;
    display: block;
  }

  .info-box h3 {
    font-size: 2.5rem;
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1;
    margin-bottom: 15px;
  }

  .address-text { color: #888; font-size: 1.1rem; margin: 0; }

  .divider {
    height: 1px;
    background: rgba(255,255,255,0.05);
    margin: 25px 0;
  }

  .summary-text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #bbb;
    margin-bottom: 20px;
  }

  .horarios-tag {
    font-weight: 900;
    font-size: 0.75rem;
    color: #d83135;
    text-transform: uppercase;
    margin: 0;
  }

  /* --- BOTONES --- */
  .social-links { display: grid; gap: 10px; }

  .social-btn {
    padding: 18px;
    text-align: center;
    text-decoration: none !important;
    font-weight: 900;
    font-size: 0.8rem;
    letter-spacing: 1px;
    transition: all 0.3s ease;
  }

  .wa { background: #d83135; color: white !important; }
  .ig { border: 1px solid rgba(255,255,255,0.1); color: white !important; }

  .social-btn:hover {
    background: white !important;
    color: #121212 !important;
    transform: translateY(-2px);
  }

  .footer-bottom {
    text-align: center;
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 30px;
  }

  .footer-bottom p { font-size: 0.7rem; color: #444; letter-spacing: 1px; margin: 0; }

  /* --- RESPONSIVE --- */
  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; }
    .info-box { padding: 30px; }
  }

  @media (max-width: 768px) {
    .map-box { 
      display: flex;
      flex-direction: column; /* Pasa la etiqueta arriba del mapa en celulares */
      gap: 10px;
    }
    .status-tag {
      writing-mode: horizontal-tb; /* Vuelve el texto a la normalidad */
      transform: none;
      padding: 8px 15px;
      width: fit-content;
    }
  }
</style>