---
// Datos de contacto institucionales unificados
const contacto = {
  direccion: "Bartolomé Mitre 764, A4400 Salta",
  colegio: "Colegio Belgrano",
  weboficial: "https://colegiobelgrano.edu.ar/", 
  instagram: "https://instagram.com/colegiobelgrano"
};
---

<footer class="footer-section">
  <div class="footer-container">
    <div class="contact-grid">
      
      <div class="contact-card map-box">
        <div class="map-label">
          <span class="status-tag">UBICACIÓN TALLER</span>
        </div>
        <div class="map-iframe-wrapper">
          <iframe 
            src="https://maps.google.com/maps?q=Colegio+Belgrano+Salta+Bartolome+Mitre+764&t=&z=15&ie=UTF8&iwloc=&output=embed" 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
      </div>

      <div class="contact-card info-box">
        <div class="info-content">
          <span class="label">Salta - Argentina</span>
          <h3>COLEGIO BELGRANO</h3>
          <p class="address-text">{contacto.direccion}</p>
          
          <div class="divider"></div>
          
          <p class="summary-text">
            Espacio exclusivo para la comunidad educativa del Colegio. Consultas sobre inscripciones y niveles por canales oficiales.
          </p>
        </div>
        
        <div class="social-links">
          <a href={contacto.weboficial} class="social-btn web-colegio" target="_blank" rel="noopener noreferrer">
            <span>WEB DEL COLEGIO</span>
          </a>
          <a href={contacto.instagram} class="social-btn ig-colegio" target="_blank" rel="noopener noreferrer">
            <span>INSTAGRAM OFICIAL</span>
          </a>
        </div>
      </div>

    </div>

    <div class="footer-bottom">
      <p>© {new Date().getFullYear()} Taller de Robótica - Colegio Belgrano Salta</p>
    </div>
  </div>
</footer>

<style>
  /* --- CONTENEDOR PRINCIPAL --- */
  .footer-section {
    background-color: #121212;
    padding: 80px 0 20px;
    color: white;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 5%;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: 20px;
    margin-bottom: 60px;
  }

  .contact-card {
    background: #1e1e1e;
    display: flex;
    flex-direction: column;
    min-height: 450px;
    border: 1px solid rgba(255,255,255,0.05);
  }

  /* --- MAP BOX Y TEXTO VERTICAL --- */
  .map-box { 
    display: grid;
    grid-template-columns: auto 1fr;
    padding: 15px; 
    gap: 15px; 
  }
  
  .map-label {
    position: relative;
    top: 0;
    left: 0;
    display: flex;
    align-items: flex-start; 
  }

  .status-tag {
    background: #d83135;
    color: white;
    padding: 20px 8px; 
    font-weight: 900;
    font-size: 0.75rem;
    letter-spacing: 3px;
    white-space: nowrap;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  .map-iframe-wrapper {
    width: 100%;
    height: 100%;
    background: #252525;
    min-height: 350px;
  }

  /* --- INFO BOX --- */
  .info-box {
    padding: 40px;
    justify-content: space-between;
  }

  .label {
    color: #d83135;
    font-weight: 900;
    font-size: 0.7rem;
    letter-spacing: 2px;
    margin-bottom: 10px;
    display: block;
  }

  .info-box h3 {
    font-size: 2.5rem;
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1;
    margin-bottom: 15px;
  }

  .address-text { 
    color: #888; 
    font-size: 1.1rem; 
    margin: 0; 
  }

  .divider {
    height: 1px;
    background: rgba(255,255,255,0.05);
    margin: 25px 0;
  }

  .summary-text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #bbb;
    margin-bottom: 20px;
  }

  /* --- BOTONES INSTITUCIONALES --- */
  .social-links { 
    display: grid; 
    gap: 10px; 
  }

  .social-btn {
    padding: 18px;
    text-align: center;
    text-decoration: none !important;
    font-weight: 900;
    font-size: 0.8rem;
    letter-spacing: 1px;
    transition: all 0.3s ease;
    box-sizing: border-box;
  }

  .web-colegio { 
    background: #d83135; 
    color: white !important; 
  }
  
  .ig-colegio { 
    border: 1px solid rgba(255,255,255,0.1); 
    color: white !important; 
  }

  .social-btn:hover {
    background: white !important;
    color: #121212 !important;
    transform: translateY(-2px);
  }

  /* --- PIE DE PÁGINA --- */
  .footer-bottom {
    text-align: center;
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 30px;
  }

  .footer-bottom p { 
    font-size: 0.7rem; 
    color: #444; 
    letter-spacing: 1px; 
    margin: 0; 
  }

  /* --- ADAPTACIÓN RESPONSIVE --- */
  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; }
    .info-box { padding: 30px; }
  }

  @media (max-width: 768px) {
    .map-box { 
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    
    .status-tag {
      writing-mode: horizontal-tb;
      transform: none;
      padding: 8px 15px;
      width: fit-content;
    }
  }
</style>