---

<section class="niveles-wrapper" id="nivelesWrapper">
  <div class="vertical-title"><span>NIVELES</span></div>

  <div class="niveles-container" id="levelsContainer">
    {levels.map((level) => (
      <div class="level-bar" data-id={level.id}>
        <div class="level-content">
          
          {/* VISTA CERRADA */}
          <div class="main-info">
            <div class="text-area">
              <h3>{level.nombre}</h3>
              <p>{level.descripcion}</p>
            </div>
            <div class="horizontal-video">
              <video muted loop playsinline preload="auto">
                <source src={level.video} type="video/mp4" />
              </video>
            </div>
          </div>

          {/* VISTA EXPANDIDA */}
          <div class="expanded-info">
            <div class="expanded-layout">
              <div class="expanded-text">
                <button class="btn-close-level">← VOLVER</button>
                
                <div class="text-content-limit">
                  <h4>Objetivos del Nivel</h4>
                  <div class="detail-content" set:html={level.detalleExtra}></div>

                  <a href={`/niveles/${level.slug}`} class="btn-discover">
                    DESCUBRIR EXPERIENCIA COMPLETA →
                  </a>
                </div>
              </div>
              
              <div class="vertical-video">
                <video muted loop playsinline preload="auto">
                  <source src={level.video} type="video/mp4" />
                </video>
              </div>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  /* --- LAYOUT BASE --- */
  .niveles-wrapper {
    position: relative;
    background: #121212;
    padding: 8rem 0; 
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .niveles-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    transition: transform 0.5s ease-in-out;
  }

  /* --- TARJETAS DE NIVELES --- */
  .level-bar {
    background: #8b1d20;
    width: 75vw;
    min-height: 180px;
    max-height: 180px;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    overflow: hidden;
    position: relative;
    z-index: 5;
    pointer-events: auto; /* IMPORTANTE: Asegura que detecte el ratón */
  }

  @media (hover: hover) {
    .level-bar:not(.is-expanded):hover {
      width: 80vw;
      background: #d83135;
    }
  }

  .level-bar:not(.is-expanded):active {
    background: #a32225;
    transform: scale(0.99);
    transition: all 0.1s ease;
  }

  .level-bar.is-expanded {
    min-height: 500px;
    max-height: 1500px; 
    width: 85vw;
    background: #222222; 
    cursor: default;
    z-index: 10;
    margin-left: 2vw;
    box-shadow: 0 0 60px rgba(0,0,0,0.8);
  }

  .niveles-container.has-expanded .level-bar:not(.is-expanded) {
    min-height: 0;
    max-height: 0;
    opacity: 0;
    margin: 0;
    padding: 0;
    pointer-events: none;
    transition: all 0.4s ease-in-out;
  }

  .level-content { 
    display: grid;
    width: 100%;
    height: 100%;
  }

  .main-info, .expanded-info {
    grid-area: 1 / 1; 
    width: 100%;
  }

  .main-info {
    display: flex;
    height: 180px; 
    align-items: center;
    justify-content: space-between;
    padding-left: 4rem;
    transition: opacity 0.3s ease-out; 
    opacity: 1;
    z-index: 2;
  }

  .level-bar.is-expanded .main-info { 
    opacity: 0; 
    pointer-events: none;
    transition: opacity 0.1s ease-in; 
  }

  .text-area h3 { 
    font-size: 2.2rem; 
    font-weight: 900; 
    text-transform: uppercase; 
    margin: 0; 
    color: white;
    white-space: normal; 
    line-height: 1.1;
  }
  
  .text-area p { color: rgba(255,255,255,0.7); font-size: 1.1rem; margin-top: 5px; max-width: 90%; }

  /* CORRECCIÓN: pointer-events none para no interceptar el hover del padre */
  .horizontal-video { 
    width: 350px; 
    height: 180px; 
    background: #000; 
    position: relative; 
    pointer-events: none; 
  }

  /* --- VISTA EXPANDIDA --- */
  .expanded-info { 
    opacity: 0; 
    transition: opacity 0.2s ease-in; 
    z-index: 1;
    pointer-events: none;
  }

  .level-bar.is-expanded .expanded-info { 
    opacity: 1; 
    pointer-events: auto;
    z-index: 3;
    transition: opacity 0.4s ease-out 0.3s; 
  }

  .expanded-layout { 
    display: grid; 
    grid-template-columns: 1.2fr 0.8fr; 
    min-height: 500px; 
  }

  .expanded-text { 
    padding: 4rem; 
    display: flex; 
    flex-direction: column;
    justify-content: flex-start; 
  }

  .text-content-limit { max-width: 580px; }

  .detail-content {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #cecece;
    margin-bottom: 2.5rem;
    -webkit-font-smoothing: antialiased;
  }

  :global(.detail-content strong) {
    color: #ffffff; 
    font-weight: 700; 
    display: inline-block;
  }

  .btn-discover {
    display: inline-block;
    background: #d83135;
    color: #ffffff;
    padding: 0.9rem 2rem;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    transition: all 0.3s ease;
    width: fit-content;
  }

  .btn-discover:hover { background: #b11b1f; transform: translateX(10px); }

  .btn-close-level {
    align-self: flex-start;
    background: transparent;
    color: #888;
    border: 1px solid #444;
    padding: 0.5rem 1rem;
    font-weight: 700;
    cursor: pointer;
    margin-bottom: 2rem;
    transition: all 0.3s ease;
    text-transform: uppercase;
    font-size: 0.75rem;
  }

  .btn-close-level:hover { color: white; border-color: #d83135; }

  .expanded-text h4 { color: #d83135; font-size: 1.8rem; text-transform: uppercase; margin-bottom: 1.2rem; font-weight: 900; }

  /* --- VIDEOS --- */
  .vertical-video { width: 100%; height: 100%; background: #000; position: relative; pointer-events: none; }

  video {
    position: absolute; 
    top: 0; left: 0; width: 100%; height: 100%;
    object-fit: cover;
    filter: grayscale(100%) brightness(0.3);
    transition: all 0.6s ease;
    pointer-events: none; /* EL VIDEO NO DEBE INTERCEPTAR EL MOUSE */
  }

  .level-bar:hover video, .level-bar.is-expanded video { filter: grayscale(0%) brightness(1); }

  /* --- TITULO DE FONDO --- */
  .vertical-title { position: absolute; right: 30px; top: 50%; transform: translateY(-50%); z-index: 0; }
  .vertical-title span { writing-mode: vertical-rl; font-size: 8rem; font-weight: 900; color: rgba(255,255,255,0.02); text-transform: uppercase; }

  /* --- MEDIA QUERIES --- */
  @media (max-width: 1024px) {
    .horizontal-video, .vertical-video { display: none !important; }
    .level-bar { width: 100%; min-height: 200px; max-height: 200px; }
    .level-bar.is-expanded { width: 100%; margin-left: 0; min-height: 0 !important; max-height: 1500px; }
    .main-info { height: 200px; padding: 0 2rem; flex-direction: column; justify-content: center; align-items: flex-start; }
    .text-area h3 { font-size: 1.8rem; white-space: normal; }
    .text-area p { font-size: 1rem; margin: 0.5rem 0 1rem; }
    .expanded-layout { display: block; min-height: auto; }
    .expanded-text { padding: 3rem 2rem 2rem 2rem !important; justify-content: flex-start !important; }
    .btn-close-level { margin-top: 0; margin-bottom: 1.5rem; } 
    .expanded-text h4 { font-size: 1.5rem; margin-top: 0; margin-bottom: 1rem; } 
    .vertical-title { display: none; }
  }

  @media (max-width: 768px) {
    .niveles-wrapper { padding: 4rem 0; }
    .level-bar { min-height: 150px; max-height: 150px; }
    .main-info { height: 150px; padding: 0 1.5rem; }
    .expanded-text { padding: 2.5rem 1.5rem !important; } 
    .text-area h3 { font-size: 1.6rem; }
    .btn-discover { width: 100%; box-sizing: border-box; text-align: center; }
  }
</style>

<script>
  const setupLevels = () => {
    const container = document.getElementById('levelsContainer');
    const bars = document.querySelectorAll('.level-bar');

    bars.forEach(bar => {
      const hVideo = bar.querySelector('.horizontal-video video') as HTMLVideoElement;
      const vVideo = bar.querySelector('.vertical-video video') as HTMLVideoElement;
      
      const safePlay = (video: HTMLVideoElement | null) => {
        if (!video) return;
        video.muted = true;
        const playPromise = video.play();
        if (playPromise !== undefined) {
          playPromise.catch(() => {});
        }
      };

      const syncAndPlay = (from: HTMLVideoElement, to: HTMLVideoElement) => {
        if (!to) return;
        to.currentTime = from.currentTime;
        safePlay(to);
      };

      // --- HOVER ACTIVA VIDEO ---
      bar.addEventListener('mouseenter', () => {
        if (!bar.classList.contains('is-expanded')) {
          if (hVideo) safePlay(hVideo);
        }
      });

      bar.addEventListener('mouseleave', () => {
        if (!bar.classList.contains('is-expanded')) {
          if (hVideo) {
            hVideo.pause();
            hVideo.currentTime = 0;
          }
        }
      });

      // --- CLIC ---
      bar.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        
        if (target.classList.contains('btn-close-level')) {
          if (vVideo && hVideo) syncAndPlay(vVideo, hVideo);
          bar.classList.remove('is-expanded');
          container?.classList.remove('has-expanded');
          setTimeout(() => { if(vVideo) vVideo.pause(); }, 500);
          e.stopPropagation();
          return;
        }

        if (!bar.classList.contains('is-expanded')) {
          if (hVideo && vVideo) syncAndPlay(hVideo, vVideo);
          bars.forEach(b => b.classList.remove('is-expanded'));
          bar.classList.add('is-expanded');
          container?.classList.add('has-expanded');

          const wrapper = document.getElementById('nivelesWrapper');
          if (wrapper) {
            const topOffset = wrapper.getBoundingClientRect().top + window.scrollY;
            window.scrollTo({ top: topOffset - 20, behavior: 'smooth' });
          }
        }
      });
    });
  };

  setupLevels();
  document.addEventListener('astro:page-load', setupLevels);
</script>