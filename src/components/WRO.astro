---
const trophies = [
  {
    slug: 'temporada-2026',
    year: '2026',
    title: 'Temporada 2026',
    desc: 'Conocé los desafíos de este año, las temáticas planteadas y nuestros planes para la competencia.',
    size: 'bento-big', 
    img: '/images/wro/wro2026-planes.jpg' // Imagen principal de planes actuales
  },
  {
    slug: 'mundial-turquia-2024',
    year: '2024',
    title: 'Mundial Turquía',
    desc: 'Nuestra histórica experiencia en Izmir representando a Salta frente a la élite tecnológica.',
    size: 'bento-wide',
    img: '/images/wro/wro2024-izmir.jpg'
  },
  {
    slug: 'nacional-misiones-2025',
    year: '2025',
    title: 'Nacional Misiones',
    desc: 'Un gran desempeño federal logrando el 2do Puesto en la categoría Senior.',
    size: 'bento-wide',
    img: '/images/wro/wro2025-misiones.jpg'
  }
];
---

<section class="wro-section" id="wro">
  <div class="wro-limit">
    <header class="wro-intro">
      <div class="intro-main">
        <span class="wro-badge">COMPETENCIA INTERNACIONAL</span>
        <h2>World Robot Olympiad</h2>
        <p class="main-desc">
          La <strong>WRO</strong> es la competencia de robótica educativa más importante del mundo, presente en más de 90 países. 
          En nuestro Taller (a partir de Nivel 2) participamos en la categoría "Future Innovators", en la que debemos brindar una solución robótica creativa a un problema planteado como temática de la temporada. En la competencia, los jueces evalúan la solución técnica, la innovación y la presentación del proyecto.
        </p>
      </div>
    </header>

    <div class="bento-container">
      {trophies.map(t => (
        <a href={`/wro/${t.slug}`} class={`bento-box ${t.size}`} style={`background-image: url(${t.img})`}>
          <div class="bento-gradient"></div>
          <div class="bento-info">
            <span class="bento-tag">{t.year}</span>
            <h3>{t.title}</h3>
            <p>{t.desc}</p>
            <span class="read-more-btn">VER DETALLES →</span>
          </div>
        </a>
      ))}
    </div>

    <div class="wro-footer-action">
      <a href="/wro" class="btn-history">VER HISTORIAL COMPLETO DE NOTICIAS →</a>
    </div>

  </div>
</section>

<style>
  /* --- ESTILOS GENERALES DE LA SECCIÓN --- */
  .wro-section { background-color: #ffffff !important; padding: 100px 0; width: 100%; color: #121212; }
  .wro-limit { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
  
  /* Ajustamos el header eliminando el panel lateral de estadísticas */
  .wro-intro { margin-bottom: 60px; max-width: 850px; }
  .wro-badge { color: #d83135; font-weight: 900; letter-spacing: 2px; font-size: 0.9rem; display: block; margin-bottom: 10px; text-transform: uppercase; }
  .wro-intro h2 { font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 900; text-transform: uppercase; color: #121212; margin: 0; line-height: 0.9; }
  .main-desc { font-size: 1.15rem; color: #444; margin-top: 25px; line-height: 1.6; }
  .main-desc strong { color: #d83135; font-weight: 900; }
  
  /* --- GRILLA BENTO --- */
  .bento-container { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; width: 100%; }
  .bento-box { position: relative; background-size: cover; background-position: center; background-color: #1a1a1a; min-height: 300px; display: flex; align-items: flex-end; overflow: hidden; text-decoration: none !important; color: white !important; transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); }
  
  /* Tarjeta destacada de la temporada actual (ocupa 2 filas) */
  .bento-big { grid-row: span 2; min-height: 620px; }
  .bento-wide { grid-column: span 1; }
  
  .bento-gradient { position: absolute; inset: 0; background: linear-gradient(0deg, rgba(139, 29, 32, 0.85) 0%, rgba(0,0,0,0.1) 100%); z-index: 1; transition: all 0.4s ease; }
  .bento-info { position: relative; z-index: 2; padding: 35px; width: 100%; transform: translateY(25px); transition: transform 0.4s ease; }
  .bento-tag { background: #d83135; color: white; padding: 4px 10px; font-weight: 900; font-size: 0.75rem; display: inline-block; margin-bottom: 12px; }
  .bento-info h3 { color: #ffffff !important; font-size: 2.2rem; font-weight: 900; text-transform: uppercase; margin: 0; line-height: 1.1; }
  .bento-info p { color: rgba(255,255,255,0.9); margin: 12px 0 20px; font-size: 1.05rem; line-height: 1.4; opacity: 0; transition: opacity 0.4s ease; }
  .read-more-btn { display: inline-block; color: #ffffff !important; font-weight: 900; font-size: 0.8rem; letter-spacing: 2px; text-transform: uppercase; border-bottom: 2px solid #d83135; padding-bottom: 4px; opacity: 0; transition: all 0.4s ease; }
  
  /* --- ANIMACIONES HOVER --- */
  .bento-box:hover { transform: scale(0.985); }
  .bento-box:hover .bento-gradient { background: linear-gradient(0deg, rgba(18, 18, 18, 0.95) 0%, rgba(0,0,0,0.3) 100%); }
  .bento-box:hover .bento-info { transform: translateY(0); }
  .bento-box:hover p, .bento-box:hover .read-more-btn { opacity: 1; }
  .bento-box:hover .read-more-btn { color: #d83135 !important; }

  /* --- BOTÓN ACCIÓN INFERIOR --- */
  .wro-footer-action { display: flex; justify-content: center; margin-top: 60px; }
  .btn-history { display: inline-block; background: #121212; color: #ffffff; padding: 1rem 3rem; font-weight: 900; font-size: 0.9rem; letter-spacing: 2px; text-transform: uppercase; text-decoration: none; border: 2px solid #121212; transition: all 0.3s ease; }
  .btn-history:hover { background: #d83135; border-color: #d83135; transform: translateY(-5px); box-shadow: 0 10px 20px rgba(216, 49, 53, 0.3); }

  /* --- RESPONSIVE --- */
  @media (max-width: 768px) {
    .bento-container { grid-template-columns: 1fr; }
    .bento-big { grid-row: span 1; min-height: 400px; }
    .bento-info { transform: translateY(0); padding: 25px; }
    .bento-info p, .read-more-btn { opacity: 1; }
    .bento-info h3 { font-size: 1.8rem; }
    .wro-intro h2 { font-size: 2.5rem; }
  }
</style>