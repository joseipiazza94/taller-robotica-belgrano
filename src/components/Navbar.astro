<header id="navbar" class="hero-header">
  <div class="header-content">
    <a href="/#explorar" class="brand-link" id="navBrand">
      <div class="brand-wrapper">
        <div class="title-logo-row">
          <h1 class="main-title">TALLER DE<br />ROBOTICA</h1>
          <img src="/logo-belgrano.png" alt="Logo" class="side-logo" />
          <span class="nav-subtitle-inline">COLEGIO BELGRANO</span>
        </div>
        
        <div class="subtitle-container">
          <span class="decor-line"></span>
          <span class="subtitle">COLEGIO BELGRANO</span>
          <span class="decor-line"></span>
        </div>
      </div>
    </a>

    <nav class="nav-menu">
      <a href="/#pilares" class="nav-link">PILARES</a>
      <a href="/#niveles" class="nav-link">NIVELES</a>
      <a href="/#wro" class="nav-link">COMPETENCIA</a>
      <a href="/#contacto" class="nav-link">CONTACTO</a>
    </nav>
  </div>
</header>

<style>
  /* --- ESTILOS BASE --- */
  .hero-header {
    position: fixed; top: 0; left: 0; width: 100%; height: 100px; 
    display: flex; align-items: center; z-index: 1000; 
    opacity: 0; 
    visibility: hidden;
  }

  .hero-header.ready { 
    opacity: 1;
    visibility: visible;
    transition: all 0.4s ease, opacity 0.5s ease; 
  }

  .header-content { 
    width: 100%; display: flex; justify-content: center; align-items: center;
    padding: 0 5%; 
  }

  .hero-header.ready .header-content { 
    transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1); 
  }

  .brand-link { text-decoration: none; color: inherit; display: block; transition: all 0.5s ease; }
  .brand-wrapper { display: inline-flex; flex-direction: column; }
  
  .title-logo-row { display: flex; align-items: center; gap: 2rem; }
  
  .hero-header.ready .title-logo-row { 
    transition: gap 0.5s ease; 
  }

  .main-title { 
    font-size: clamp(3rem, 10vw, 8rem); line-height: 0.85; margin: 0;
    font-weight: 900; text-transform: uppercase;
    background: linear-gradient(135deg, #ffffff 0%, #cccccc 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }

  .side-logo { height: clamp(4.5rem, 15vw, 12rem); width: auto; object-fit: contain; }
  
  .hero-header.ready .side-logo { 
    transition: height 0.5s ease; 
  }

  .nav-subtitle-inline {
    display: none;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
    font-weight: 300;
    letter-spacing: 3px;
    border-left: 1px solid rgba(216, 49, 55, 0.4);
    padding-left: 1.5rem;
    margin-left: 0.5rem;
    text-transform: uppercase;
  }

  .subtitle-container { display: flex; align-items: center; justify-content: space-between; width: 100%; margin-top: 0.5rem; }
  .subtitle {
    font-size: clamp(0.7rem, 1.2vw, 1.2rem); font-weight: 300; letter-spacing: 0.8em; padding: 0 1rem;
    color: rgba(255, 255, 255, 0.9); text-transform: uppercase;
  }
  .decor-line { flex-grow: 1; height: 1px; background-color: #d53037; opacity: 0.8; }

  /* --- NAVEGACIÓN --- */
  .nav-menu {
    position: absolute; right: 5%; display: flex; gap: 2.5rem;
    opacity: 0; visibility: hidden; transition: opacity 0.3s ease;
  }

  .nav-link { 
    color: white; 
    text-decoration: none; 
    font-weight: 500;
    font-size: 0.85rem;
    letter-spacing: 2px; 
    text-transform: uppercase;
    position: relative;
    padding: 8px 0;
    transition: color 0.3s ease;
  }

  .nav-link::after {
    content: ''; position: absolute; bottom: 0; left: 0; width: 0; height: 2px;
    background: #d53037; transition: width 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .nav-link:hover { color: #d53037; }
  .nav-link:hover::after { width: 100%; }

  /* --- ESTADO SCROLLED (PC) --- */
  .hero-header.scrolled { background-color: rgba(10, 10, 10, 0.95); backdrop-filter: blur(15px); height: 80px; }
  .hero-header.scrolled .header-content { justify-content: flex-start; }
  .hero-header.scrolled .title-logo-row { gap: 1.2rem; }
  .hero-header.scrolled .main-title { font-size: 1.3rem; -webkit-text-fill-color: white; }
  .hero-header.scrolled .side-logo { height: 38px; }
  .hero-header.scrolled .nav-subtitle-inline { display: block; }
  .hero-header.scrolled .subtitle-container { display: none; }
  .hero-header.scrolled .nav-menu { opacity: 1; visibility: visible; pointer-events: auto; }

  /* --- RESPONSIVE: NUEVA DISTRIBUCIÓN MÓVIL --- */
  @media (max-width: 1024px) {
    /* Mantenemos el logo gigante centrado al inicio (sin scrolled) */
    .header-content { flex-direction: column; }
    
    /* Cuando se activa SCROLLED en móvil */
    .hero-header.scrolled {
      height: 105px; /* Un poco más alto para las dos filas */
    }

    .hero-header.scrolled .header-content {
      padding: 10px 0;
      gap: 12px;
    }

    /* FILA 1: Logo y Título */
    .hero-header.scrolled .title-logo-row {
      gap: 0.8rem;
      justify-content: center;
      width: 100%;
    }
    
    .hero-header.scrolled .main-title {
      font-size: 1.1rem; /* Más compacto para que entre todo */
    }

    .hero-header.scrolled .side-logo {
      height: 30px;
    }

    .hero-header.scrolled .nav-subtitle-inline {
      display: none; /* Quitamos el subtítulo inline para ganar espacio horizontal */
    }

    /* FILA 2: Menú de Navegación */
    .hero-header.scrolled .nav-menu {
      position: static; /* Vuelve al flujo normal debajo del logo */
      display: flex;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      gap: 1.2rem;
      justify-content: center;
      width: 100%;
      padding-top: 5px;
      border-top: 1px solid rgba(255,255,255,0.05); /* Separador sutil */
    }

    .hero-header.scrolled .nav-link {
      font-size: 0.65rem; /* Letra pequeña pero legible */
      letter-spacing: 1px;
      padding: 4px 0;
    }

    /* Ajuste para que el subrayado no choque */
    .nav-link::after { height: 1px; }
  }

  /* Ajuste extra para celulares muy pequeños */
  @media (max-width: 380px) {
    .hero-header.scrolled .nav-menu { gap: 0.8rem; }
    .hero-header.scrolled .main-title { font-size: 0.9rem; }
  }
</style>

<script is:inline>
  window.navbarScrollHandler = window.navbarScrollHandler || null;

  const initNavbarSmooth = () => {
    const header = document.getElementById('navbar');
    const content = header ? header.querySelector('.header-content') : null;
    if (!header || !content) return;

    header.classList.remove('ready');

    const isHome = window.location.pathname === '/' || window.location.pathname === '/index.html';

    if (window.navbarScrollHandler) {
      window.removeEventListener('scroll', window.navbarScrollHandler);
    }

    window.navbarScrollHandler = () => {
      if (!isHome) { 
        header.classList.add('scrolled'); 
        content.style.transform = 'translateY(0)'; 
        return; 
      }
      
      const scrollY = window.scrollY;
      const vh = window.innerHeight;
      const startRising = vh; 
      const endRising = vh * 1.5;

      if (scrollY < startRising) {
        header.classList.remove('scrolled');
        // Centrado vertical inicial
        content.style.transform = `translateY(calc(50vh - 50px))`;
      } else if (scrollY >= startRising && scrollY <= endRising) {
        header.classList.remove('scrolled');
        const progress = (scrollY - startRising) / (vh * 0.5);
        const currentY = 50 * (1 - progress);
        content.style.transform = `translateY(calc(${currentY}vh - ${50 * (1 - progress)}px))`;
      } else {
        header.classList.add('scrolled');
        content.style.transform = 'translateY(0)';
      }
    };

    window.addEventListener('scroll', window.navbarScrollHandler);
    window.navbarScrollHandler();

    setTimeout(() => {
      header.classList.add('ready');
    }, 50); 
  };

  initNavbarSmooth();
  document.addEventListener('astro:after-swap', initNavbarSmooth);
</script>