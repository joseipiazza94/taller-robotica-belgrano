---
const pilares = [
  { 
    id: 'quienes', 
    titulo: 'Quiénes Somos', 
    resumen: 'Un espacio para descubrir la tecnología a través de la práctica.', 
    detalle: `
      <strong>Un equipo apasionado por la tecnología y la educación.</strong><br /><br />
      Somos un taller pensado para que los alumnos se familiaricen con la robótica de forma natural, encontrando su vocación a través del código y la ingeniería. <br /><br />
      El taller es impulsado por la <strong>Ing. Ana Chalabe</strong> y por <strong>Florencia Piazza</strong>, docente experta en ilustración y animación. <br /><br />
      Todo esto es posible gracias al marco del <strong>Colegio Belgrano</strong>, que nos brinda el entorno necesario para crear.
    `,
    puntos: [
      { label: 'Exploración', desc: 'Herramientas reales de programación.' },
      { label: 'Vocaciones', desc: 'Primer paso hacia la ingeniería.' },
      { label: 'Trayectoria', desc: 'Visión técnica y pedagógica.' },
      { label: 'Valores', desc: 'Respaldo del Colegio Belgrano.' }
    ],
    imagen: '/images/quienes-somos.jpg'
  },
  { 
    id: 'que', 
    titulo: 'Qué Hacemos', 
    resumen: 'Robótica educativa y experimentación real.', 
    detalle: `
      <strong>Prototipado, programación y pensamiento creativo.</strong><br /><br />
      Desde la construcción física hasta el desarrollo de algoritmos inteligentes. Nuestro taller abarca el diseño mecánico y la programación en entornos profesionales para resolver desafíos del mundo real.<br /><br />
      Buscamos que los alumnos comprendan la tecnología desde adentro, integrando electrónica y lógica en cada sesión.
    `,
    puntos: [
      { label: 'Prototipado', desc: 'Diseño y montaje de estructuras.' },
      { label: 'Programación', desc: 'Entornos visuales y de código.' },
      { label: 'WRO', desc: 'Preparación para competencia internacional.' },
      { label: 'Autonomía', desc: 'Resolución de retos técnicos.' }
    ],
    imagen: '/images/que-hacemos.jpg'
  },
  { 
    id: 'porque', 
    titulo: 'Por Qué', 
    resumen: 'Crear tecnología, no solo consumirla.', 
    detalle: `
      <strong>Empoderando a los creadores del futuro.</strong><br /><br />
      El objetivo de este taller es que los alumnos dejen de ser usuarios pasivos y se conviertan en los creadores del mañana. <br /><br />
      Fomentamos el pensamiento crítico, la resolución de problemas complejos y la resiliencia ante el error, herramientas fundamentales para cualquier camino profesional.
    `,
    puntos: [
      { label: 'Crítica', desc: 'Análisis profundo de problemas.' },
      { label: 'Liderazgo', desc: 'Gestión de proyectos propios.' },
      { label: 'Resiliencia', desc: 'Aprendizaje a través del error.' },
      { label: 'Futuro', desc: 'Habilidades para el siglo XXI.' }
    ],
    imagen: '/images/por-que.jpg'
  },
  { 
    id: 'como', 
    titulo: 'Cómo', 
    resumen: 'Metodología basada en proyectos y niveles.', 
    detalle: `
      <strong>Un camino de aprendizaje estructurado y progresivo.</strong><br /><br />
      Nuestra metodología se basa en niveles de progresión técnica diseñados para acompañar el crecimiento cognitivo y la autonomía del alumno en cada etapa. <br /><br />
      Trabajamos con proyectos reales donde el conocimiento se adquiere de forma práctica y aplicada.
    `,
    puntos: [
      { label: 'Niveles', desc: 'Escalabilidad en dificultad técnica.' },
      { label: 'ABP', desc: 'Aprendizaje basado en proyectos.' },
      { label: 'Seguimiento', desc: 'Atención personalizada por niveles.' },
      { label: 'Herramientas', desc: 'Software y hardware profesional.' }
    ],
    imagen: '/images/como-lo-hacemos.jpg'
  }
];
---

<section class="pilares-section" id="pilaresSection">
  <div class="pilares-grid" id="pilaresGrid">
    {pilares.map(pilar => (
      <div class="pilar-card" data-id={pilar.id} style={`--bg-image: url(${pilar.imagen})`}>
        
        {/* VISTA CERRADA - Centrado Mejorado */}
        <div class="pilar-closed">
            <h2>{pilar.titulo}</h2>
            <p class="summary-text">{pilar.resumen}</p>
        </div>
        
        {/* VISTA ABIERTA */}
        <div class="pilar-opened">
          <div class="opened-banner">
             <h3>{pilar.titulo}</h3>
          </div>

          <div class="content-wrapper">
            <div class="detail-grid">
              
              <div class="text-detail">
                <div class="pilar-separator"></div>
                <div class="full-body-text" set:html={pilar.detalle}></div>
                
                <div class={`action-footer ${pilar.id === 'que' ? 'footer-right' : ''}`}>
                  <a href={`/pilares/${pilar.id}`} class="btn-more">CONOCER MÁS →</a>
                </div>
              </div>

              <div class="image-side">
                <div class="side-info-container">
                  <ul class="pilar-bullets">
                    {pilar.puntos.map(punto => (
                      <li><strong>{punto.label}:</strong> {punto.desc}</li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <button class="close-tab-mobile" aria-label="Cerrar pilar">
            <span>VOLVER AL MENÚ</span>
          </button>
        </div>

        <button class="close-tab-desktop" aria-label="Cerrar pilar">
          <span>CERRAR</span>
        </button>

      </div>
    ))}
  </div>
</section>

<style>
  .pilares-section { background: #121212; min-height: 85vh; display: flex; align-items: center; overflow: hidden; position: relative; }

  /* --- GRID DESKTOP --- */
  .pilares-grid { 
    display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; 
    width: 100vw; height: 85vh; transition: all 0.8s cubic-bezier(0.85, 0, 0.15, 1); 
  }

  .pilares-grid.expanded-quienes { grid-template-columns: 4fr 1fr; grid-template-rows: 4fr 1fr; }
  .pilares-grid.expanded-que      { grid-template-columns: 1fr 4fr; grid-template-rows: 4fr 1fr; }
  .pilares-grid.expanded-porque   { grid-template-columns: 4fr 1fr; grid-template-rows: 1fr 4fr; }
  .pilares-grid.expanded-como     { grid-template-columns: 1fr 4fr; grid-template-rows: 1fr 4fr; }

  .pilar-card { 
    background-color: #8b1d20;
    background-image: linear-gradient(rgba(139, 29, 32, 0.85), rgba(139, 29, 32, 0.85)), var(--bg-image);
    background-size: cover; background-position: center;
    color: white; cursor: pointer; position: relative; overflow: hidden; 
    border: 1px solid rgba(255,255,255,0.05); transition: background 0.4s ease;
  }

  .pilar-card.is-active { background: #111; background-image: none; cursor: default; z-index: 10; }

  /* --- 1. CENTRADO CERRADO (CORREGIDO) --- */
  .pilar-closed { 
    position: absolute; inset: 0; /* Asegura que ocupe todo el espacio */
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 2rem; text-align: center; transition: opacity 0.3s ease;
    z-index: 5;
  }
  .pilar-card.is-active .pilar-closed { display: none; }
  
  .pilar-closed h2 { font-size: 2.2rem; font-weight: 900; text-transform: uppercase; margin: 0; line-height: 1; }
  .summary-text { opacity: 0.7; max-width: 280px; font-size: 1.1rem; margin-top: 1rem; }

  /* --- 2. VISTA ABIERTA & REMOCIÓN DE SCROLLBAR --- */
  .pilar-opened { 
    display: none; height: 100%; width: 100%; flex-direction: column; 
    overflow-x: hidden;
    overflow-y: auto;
    /* Ocultar barra de scroll para estética limpia en PC */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .pilar-opened::-webkit-scrollbar { display: none; }

  .pilar-card.is-active .pilar-opened { display: flex; }

  .opened-banner { 
    width: 100%; height: 180px; flex-shrink: 0;
    background-image: linear-gradient(rgba(139, 29, 32, 0.9), rgba(139, 29, 32, 0.9)), var(--bg-image);
    background-size: cover; background-position: center;
    display: flex; align-items: center; justify-content: center;
  }
  .opened-banner h3 { font-size: 2.2rem; font-weight: 900; text-transform: uppercase; margin: 0; }

  .content-wrapper { width: 100%; padding: 3rem 6%; flex-grow: 1; }
  .detail-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 5%; align-items: start; }
  
  .pilar-separator { width: 60px; height: 4px; background: #d83135; margin-bottom: 2rem; }
  .full-body-text { font-size: 1.15rem; line-height: 1.6; color: #cecece; }
  :global(.full-body-text strong) { color: #d83135; font-weight: 700; }
  
  .action-footer { margin-top: 2rem; }
  .footer-right { display: flex; justify-content: flex-end; }
  .btn-more { 
    display: inline-block; padding: 0.8rem 2rem; border: 1px solid #d83135; color: #d83135; 
    text-decoration: none; font-weight: 900; text-transform: uppercase; font-size: 0.8rem;
    transition: 0.3s ease;
  }
  .btn-more:hover { background: #d83135; color: white; }

  .pilar-bullets { list-style: none; padding: 0; }
  .pilar-bullets li { color: #aaa; margin-bottom: 0.8rem; font-size: 0.95rem; line-height: 1.4; }

  /* BOTONES CERRAR */
  .close-tab-desktop {
    position: absolute; background: #d83135; color: white; border: none; width: 45px; height: 160px;
    cursor: pointer; z-index: 100; display: none; align-items: center; justify-content: center;
    transition: 0.3s;
  }
  .close-tab-desktop span { writing-mode: vertical-rl; font-weight: 900; letter-spacing: 3px; font-size: 0.85rem; }
  .close-tab-mobile { display: none; }

  /* --- RESPONSIVE MÓVIL --- */
  @media (max-width: 1024px) {
    .pilares-section { height: auto; padding: 4rem 0; align-items: flex-start; }
    .pilares-grid { display: flex; flex-direction: column; height: auto; padding: 0 1rem; gap: 1rem; }
    
    .pilar-card { height: 180px; flex-shrink: 0; width: 100%; border-radius: 4px; }
    .pilar-card.is-active { height: auto; order: -1; }
    .pilares-grid.is-any-active .pilar-card:not(.is-active) { display: none; }

    .opened-banner { height: 180px; } 
    .content-wrapper { padding: 2rem 0; }
    .detail-grid { grid-template-columns: 1fr; gap: 2rem; }
    
    .action-footer { display: flex; justify-content: flex-end; margin-bottom: 1rem; }

    .close-tab-mobile {
      display: flex; align-items: center; justify-content: center;
      width: 100%; height: 60px; background: #d83135; color: white;
      border: none; font-weight: 900; letter-spacing: 3px; cursor: pointer;
    }
    .close-tab-desktop { display: none !important; }
  }

  @media (min-width: 1025px) {
    .pilar-card.is-active .close-tab-desktop { display: flex; }
    [data-id="quienes"] .close-tab-desktop { bottom: 0; right: 0; transform: translateX(100%); }
    [data-id="que"] .close-tab-desktop     { bottom: 0; left: 0; transform: translateX(-100%); }
    [data-id="porque"] .close-tab-desktop  { top: 0; right: 0; transform: translateX(100%); }
    [data-id="como"] .close-tab-desktop    { top: 0; left: 0; transform: translateX(-100%); }
    .pilar-card.is-active .close-tab-desktop { transform: translateX(0); transition: 0.5s ease; }
  }
</style>

<script>
  const setupPilares = () => {
    const grid = document.getElementById('pilaresGrid');
    const cards = document.querySelectorAll('.pilar-card');
    const section = document.getElementById('pilaresSection');

    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        const id = card.getAttribute('data-id');
        const target = e.target as HTMLElement;

        if (target.closest('.close-tab-mobile') || target.closest('.close-tab-desktop')) {
          grid?.setAttribute('class', 'pilares-grid');
          cards.forEach(c => c.classList.remove('is-active'));
          
          if (section) {
            const topOffset = section.getBoundingClientRect().top + window.scrollY;
            window.scrollTo({ top: topOffset - 20, behavior: 'smooth' });
          }
          e.stopPropagation();
          return;
        }

        if (!card.classList.contains('is-active')) {
          cards.forEach(c => c.classList.remove('is-active'));
          card.classList.add('is-active');
          grid?.setAttribute('class', `pilares-grid expanded-${id} is-any-active`);
          
          if (window.innerWidth <= 1024) {
            setTimeout(() => {
              card.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 100);
          }
        }
      });
    });
  };
  setupPilares();
  document.addEventListener('astro:page-load', setupPilares);
</script>