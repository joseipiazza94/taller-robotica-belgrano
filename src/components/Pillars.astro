];
---

<section class="pilares-section" id="pilaresSection">
  <div class="bg-text-pilares">PILARES</div>

  <div class="pilares-container">
    <div class="pilares-grid" id="pilaresGrid">
      {pilares.map(pilar => (
        <div class="pilar-card" data-id={pilar.id}>
          
          <div class="pilar-closed" style={`--bg-image: url(${pilar.imagen})`}>
              <h2>{pilar.titulo}</h2>
              <p class="summary-text">{pilar.resumen}</p>
          </div>
          
          <div class="pilar-opened">
            
            <div class="opened-banner" style={`--bg-image: url(${pilar.imagen})`}>
               {/* BOTÓN VOLVER ORIGINAL DE PC */}
               <button class="btn-volver btn-top" aria-label="Volver">← VOLVER</button>
               <h3>{pilar.titulo}</h3>
            </div>

            <div class="content-wrapper">
              <div class="pilar-separator"></div>
              
              <p class="intro-text">{pilar.intro}</p>

              <div class="highlights-section">
                <h4>{pilar.puntosTitulo}</h4>
                <ul class="highlights-list">
                  {pilar.puntos.map(punto => (
                    <li><strong>{punto.label}:</strong> {punto.desc}</li>
                  ))}
                </ul>
              </div>

              <p class="closing-text">{pilar.cierre}</p>
              
              <div class="action-footer">
                <a href={`/pilares/${pilar.id}`} class="btn-more">CONOCER MÁS SOBRE ESTE PILAR →</a>
                {/* BOTÓN INFERIOR CORREGIDO CON LA NUEVA CLASE ESTÉTICA */}
                <button class="btn-volver-mobile-solid" aria-label="Volver al panel">← VOLVER</button>
              </div>
            </div>
            
          </div>

        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* --- 1. SECCIÓN PRINCIPAL: CENTRADO ABSOLUTO --- */
  .pilares-section { 
    box-sizing: border-box;
    background: #121212; 
    width: 100%; 
    padding: 5rem 0; 
    position: relative; 
    overflow: hidden; 
    display: flex; 
    justify-content: center; 
    align-items: center;
  }

  /* --- TEXTO DE FONDO --- */
  .bg-text-pilares {
    position: absolute;
    left: 1.5rem; 
    top: 50%;
    transform: translateY(-50%) rotate(180deg); 
    writing-mode: vertical-rl; 
    font-size: clamp(4rem, 8vw, 10rem);
    font-weight: 900;
    color: rgba(255, 255, 255, 0.03); 
    z-index: 0; 
    pointer-events: none; 
    user-select: none;
    letter-spacing: 0.1em;
  }

  /* --- 2. CONTENEDOR CENTRAL --- */
  .pilares-container {
    box-sizing: border-box;
    width: 100%; 
    max-width: 1200px; 
    padding: 0 2rem; 
    position: relative;
    z-index: 2; 
  }

  /* --- 3. LA CUADRÍCULA BASE --- */
  .pilares-grid { 
    display: grid; 
    grid-template-columns: 1fr 1fr; 
    gap: 1.5rem; 
    width: 100%; 
  }

  .pilares-grid.has-active-card { display: block; }
  .pilares-grid.has-active-card .pilar-card:not(.is-active) { display: none; }

  /* --- 4. TARJETAS --- */
  .pilar-card { 
    box-sizing: border-box;
    width: 100%;
    border-radius: 8px; 
    overflow: hidden; 
    background: #151515;
    border: 1px solid rgba(255,255,255,0.05);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  .pilar-card.is-active {
    background: #111;
    border: 1px solid #d83135; 
  }

  /* --- 5. VISTA CERRADA --- */
  .pilar-closed { 
    box-sizing: border-box;
    width: 100%;
    min-height: 380px; 
    display: flex; 
    flex-direction: column; 
    align-items: center; 
    justify-content: center; 
    padding: 2rem; 
    cursor: pointer;
    background-color: #8b1d20; 
    background-image: linear-gradient(rgba(139, 29, 32, 0.85), rgba(139, 29, 32, 0.85)), var(--bg-image);
    background-size: cover; 
    background-position: center;
    color: white; 
    transition: background-color 0.3s ease, transform 0.3s ease;
  }
  
  .pilar-card:hover .pilar-closed { background-color: #d83135; }
  .pilar-card.is-active .pilar-closed { display: none; }
  
  .pilar-closed h2 { 
    width: 100%;
    text-align: center;
    font-size: 2.2rem; 
    font-weight: 900; 
    text-transform: uppercase; 
    margin: 0 0 1rem 0 !important; 
    padding: 0 !important;
    line-height: 1; 
    text-shadow: 0 2px 10px rgba(0,0,0,0.5); 
  }
  
  .summary-text { 
    width: 100%;
    text-align: center;
    opacity: 0.9; 
    max-width: 320px; 
    font-size: 1.05rem; 
    margin: 0 !important; 
    padding: 0 !important;
    line-height: 1.5; 
  }

  /* --- 6. VISTA ABIERTA --- */
  .pilar-opened { 
    display: none; 
    width: 100%; 
    flex-direction: column; 
    animation: fadeIn 0.4s ease forwards;
  }

  .pilar-card.is-active .pilar-opened { display: flex; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* --- BANNER Y BOTÓN VOLVER ORIGINAL DE PC --- */
  .opened-banner { 
    width: 100%; 
    height: 250px; 
    position: relative;
    background-image: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), var(--bg-image);
    background-size: cover; background-position: center;
    display: flex; align-items: center; justify-content: center;
    border-bottom: 3px solid #d83135;
  }
  
  .opened-banner h3 { 
    font-size: clamp(2rem, 4vw, 3.5rem); 
    font-weight: 900; text-transform: uppercase; margin: 0; color: white;
    text-shadow: 0 4px 15px rgba(0,0,0,0.5);
  }

  .btn-top {
    position: absolute;
    top: 1.5rem; left: 1.5rem;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(5px);
    color: white;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 4px;
    padding: 0.6rem 1.2rem;
    font-weight: 900; letter-spacing: 2px; font-size: 0.75rem;
    cursor: pointer; transition: 0.3s;
    text-transform: uppercase;
  }
  .btn-top:hover { background: #d83135; border-color: #d83135; }

  /* El botón móvil inicia totalmente apagado en escritorio */
  .btn-volver-mobile-solid {
    display: none;
  }

  /* --- CONTENIDO DE TEXTO --- */
  .content-wrapper { 
    width: 100%; 
    max-width: 900px; 
    margin: 0 auto;
    padding: 4rem 5%; 
    box-sizing: border-box; 
  }
  
  .pilar-separator { width: 60px; height: 4px; background: #d83135; margin-bottom: 2rem; border-radius: 2px; }

  .intro-text { font-size: 1.2rem; line-height: 1.6; color: #fff; margin-bottom: 2.5rem; }

  .highlights-section { 
    background: rgba(255, 255, 255, 0.03); padding: 2rem 2.5rem; 
    border-left: 4px solid #d83135; margin-bottom: 2.5rem; border-radius: 0 8px 8px 0;
  }
  .highlights-section h4 { color: #d83135; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 2px; margin-bottom: 1.5rem; font-weight: 900; }
  .highlights-list { list-style: none; padding: 0; }
  .highlights-list li { margin-bottom: 1.2rem; font-size: 1.1rem; color: #ccc; line-height: 1.5; }
  .highlights-list li strong { color: #fff; text-transform: uppercase; margin-right: 0.5rem; font-size: 0.85rem; }

  .closing-text { font-size: 1.1rem; line-height: 1.6; color: #aaa; font-style: italic; margin-bottom: 3rem; }

  /* PIE CON ACCIONES (ESCRITORIO) */
  .action-footer { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 2rem; }
  
  .btn-more { 
    display: inline-block; padding: 1rem 2rem; background: #d83135; color: white; 
    text-decoration: none; font-weight: 900; text-transform: uppercase; font-size: 0.85rem;
    transition: 0.3s ease; border-radius: 4px;
  }
  .btn-more:hover { background: white; color: #d83135; }


  /* --- 7. MODIFICACIONES EXCLUSIVAS PARA MÓVIL --- */
  @media (max-width: 1024px) {
    .pilares-section { padding: 4rem 0; }
    .bg-text-pilares { display: none; } 
    
    .pilares-container { padding: 0 1.5rem; width: 100%; max-width: 100%; }
    .pilares-grid { display: flex; flex-direction: column; width: 100%; }
    .pilar-card { width: 100%; max-width: 100%; }
    
    .pilar-closed { min-height: 280px; }
    .opened-banner { height: 180px; }
    
    .content-wrapper { 
      padding: 3rem 1rem; 
      width: 100%; 
      max-width: 100%; 
      overflow: hidden; 
    }
    
    .intro-text, .closing-text, .highlights-list li {
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    .highlights-section { padding: 1.5rem 1.2rem; }

    .btn-top { 
      display: none !important; /* Desactiva el superior en móviles */
    }

    /* CONTENEDOR FLEX DE DOS COLUMNAS ALINEADAS PARA MÓVIL */
    .action-footer {
      display: flex;
      flex-direction: row;
      gap: 1rem;
      align-items: center;
      width: 100%;
    }

    .btn-more {
      flex: 1;
      text-align: center;
      padding: 1rem 0; /* Control estricto de alto uniforme */
      font-size: 0.8rem;
    }

    /* NUEVO BOTÓN SÓLIDO MÓVIL (IDÉNTICO A CONOCER MÁS PERO EN COLOR OSCURO/GRIS ANTRACITA) */
    .btn-volver-mobile-solid {
      display: block !important; /* Enciende la variante móvil */
      flex: 1;
      padding: 1rem 0; /* Mismo alto exacto */
      background: #252525; /* Sólido, sin bordes raros */
      color: white;
      border: none !important; /* Remueve los bordes */
      border-radius: 4px;
      font-weight: 900;
      text-transform: uppercase;
      font-size: 0.8rem;
      letter-spacing: 2px;
      cursor: pointer;
      text-align: center;
      transition: background 0.3s ease;
    }

    .btn-volver-mobile-solid:hover {
      background: #333333;
    }
  }

  @media (max-width: 480px) {
    /* Si el espacio es crítico en celulares muy chicos, se apilan manteniendo el formato uniforme */
    .action-footer {
      flex-direction: column;
    }
    .btn-volver-mobile-solid, .btn-more {
      width: 100%;
    }
  }
</style>

<script>
  const setupPilares = () => {
    const grid = document.getElementById('pilaresGrid');
    const cards = document.querySelectorAll('.pilar-card');
    const section = document.getElementById('pilaresSection');

    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;

        // Se modificaron los selectores lógicos para capturar de manera limpia las dos variantes físicas (.btn-top y .btn-volver-mobile-solid)
        if (target.classList.contains('btn-top') || target.classList.contains('btn-volver-mobile-solid')) {
          grid?.classList.remove('has-active-card');
          cards.forEach(c => c.classList.remove('is-active'));
          
          if (section) {
            const topOffset = section.getBoundingClientRect().top + window.scrollY;
            window.scrollTo({ top: topOffset - 80, behavior: 'smooth' });
          }
          e.stopPropagation(); 
          return;
        }

        if (!card.classList.contains('is-active') && !target.closest('.btn-more')) {
          grid?.classList.add('has-active-card');
          cards.forEach(c => c.classList.remove('is-active'));
          card.classList.add('is-active');
          
          if (section) {
            const topOffset = section.getBoundingClientRect().top + window.scrollY;
            window.scrollTo({ top: topOffset - 80, behavior: 'smooth' }); 
          }
        }
      });
    });
  };
  
  setupPilares();
  document.addEventListener('astro:page-load', setupPilares);
</script>