---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Pillars from '../components/Pillars.astro';
import Quote from '../components/Quote.astro';
import Levels from '../components/Levels.astro';
import Hero from '../components/Hero.astro';
import WRO from '../components/WRO.astro';
import BitacoraPreview from '../components/BitacoraPreview.astro'; // Nueva importación
import Footer from '../components/Footer.astro';
---

<Layout title="Taller de Robotica - Colegio Belgrano">
    <Navbar />
    <main>
        <div class="hero-spacer"></div> 
        <Hero /> 
        <div id="explorar" class="anchor-offset"></div>
        <section id="pilares">
            <Pillars />
        </section>
        <Quote />
        <section id="niveles">
            <Levels />
        </section>
        
        {/* Agregamos la Bitácora antes de la competencia o después, según prefieras */}
        <BitacoraPreview />

        <section id="wro">
            <WRO />
        </section>
    </main>

    <section id="contacto">
        <Footer />
    </section>
</Layout>

<style>
    .hero-spacer {
        height: 100vh;
        background-color: transparent;
    }

    .anchor-offset {
        display: block;
        position: relative;
        top: -110px;
        visibility: hidden; 
    }
</style>