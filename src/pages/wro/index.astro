---
// src/pages/wro/index.astro
import ArticleLayout from '../../layouts/ArticleLayout.astro';

// Tu lista de noticias históricas unificada con el bloque Bento
const newsArchive = [
  { slug: 'temporada-2026', year: '2026', title: 'Temporada 2026: Nuestros planes', desc: 'Conocé los desafíos de este año, las temáticas planteadas y nuestros planes para la competencia.' },
  { slug: 'nacional-misiones-2025', year: '2025', title: 'Nacional Misiones WRO', desc: 'Un gran desempeño federal logrando el 2do Puesto en la categoría Senior.' },
  { slug: 'mundial-turquia-2024', year: '2024', title: 'Mundial Turquía', desc: 'Nuestra histórica experiencia en Izmir representando a Salta frente a la élite tecnológica.' }
];
---

<ArticleLayout 
  title="Hemeroteca WRO" 
  subtitle="El historial de nuestra participación en la World Robot Olympiad"
  backUrl="/#wro"
>
  <p class="lead">
    <strong>Una trayectoria de excelencia.</strong> Aquí documentamos cada desafío, cada viaje y cada logro de nuestros alumnos representando al Colegio Belgrano en las instancias locales, nacionales e internacionales.
  </p>

  <div class="news-list">
    {newsArchive.map(item => (
      <a href={`/wro/${item.slug}`} class="news-item">
        <div class="news-year">{item.year}</div>
        <div class="news-content">
          <h2>{item.title}</h2>
          <p>{item.desc}</p>
          <span class="read-link">LEER CRÓNICA →</span>
        </div>
      </a>
    ))}
  </div>

  <!-- BOTÓN VOLVER CON TU ESTÉTICA MINIMALISTA -->
  <div class="wro-archive-footer">
    <a href="/#wro" class="back-home-link">← VOLVER AL INICIO</a>
  </div>

  <style>
    .news-list { display: flex; flex-direction: column; gap: 2rem; margin-top: 4rem; }
    
    .news-item {
      display: grid; grid-template-columns: 100px 1fr; gap: 2rem;
      padding: 2rem; background: #1a1a1a; border: 1px solid #333;
      text-decoration: none; color: inherit; transition: all 0.3s ease;
    }

    .news-item:hover {
      background: #222; border-color: #d83135; transform: translateX(10px);
    }

    .news-year {
      font-size: 2.5rem; font-weight: 900; color: #d83135;
      border-right: 2px solid #333; display: flex; align-items: center; justify-content: center;
    }

    .news-content h2 { margin: 0 0 0.5rem 0 !important; font-size: 1.8rem !important; padding: 0 !important; text-transform: uppercase; }
    .news-content h2::after { display: none; }
    .news-content p { margin: 0 0 1.5rem 0; font-size: 1.1rem; color: #aaa; }
    
    .read-link {
      font-size: 0.8rem; font-weight: 900; color: #d83135; letter-spacing: 2px;
      text-transform: uppercase;
    }

    /* ESTILO BOTÓN RETORNO AL FINAL */
    .wro-archive-footer {
      margin-top: 5rem;
      border-top: 1px solid #333;
      padding-top: 2rem;
    }

    .back-home-link {
      color: #d83135;
      text-decoration: none;
      font-weight: 900;
      font-size: 0.8rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      transition: opacity 0.2s ease;
    }

    .back-home-link:hover {
      opacity: 0.7;
    }

    @media (max-width: 768px) {
      .news-item { grid-template-columns: 1fr; gap: 1rem; padding: 1.5rem; }
      .news-year { border-right: none; border-bottom: 2px solid #333; padding-bottom: 1rem; justify-content: flex-start; }
    }
  </style>
</ArticleLayout>