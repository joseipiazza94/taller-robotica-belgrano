---
import Layout from '../../layouts/Layout.astro';
// Agregamos 'type CollectionEntry' a la importación
import { getCollection, type CollectionEntry } from 'astro:content';

// Le indicamos explícitamente a la constante que es un array de entradas de bitácora
const posts: CollectionEntry<'bitacora'>[] = await getCollection('bitacora');

// Ahora 'a' y 'b' ya saben qué son y no darán error
posts.sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf());
---

<Layout title="Bitácora - Taller de Robótica">
  <main class="bitacora-container">
    <header class="bitacora-header">
      <h1>BITÁCORA DE CLASES</h1>
      <p>Explorá el progreso y las creaciones de nuestros alumnos mes a mes.</p>
    </header>

    <div class="posts-grid">
      {/* 'post' ahora hereda el tipo automáticamente y no da error */}
      {posts.map((post) => (
        <a href={`/bitacora/${post.slug}`} class="post-card">
          <div class="card-image">
            <img src={post.data.image} alt={post.data.title} />
          </div>
          <div class="card-content">
            <span class="mes-label">{post.data.mes}</span>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <span class="read-more">VER GALERÍA Y DETALLES →</span>
          </div>
        </a>
      ))}
    </div>
  </main>
</Layout>

<style>
  .bitacora-container { padding: 8rem 5% 4rem; background: #0a0a0a; min-height: 100vh; }
  .bitacora-header { text-align: center; margin-bottom: 4rem; }
  .bitacora-header h1 { font-size: 4rem; font-weight: 900; color: #d83135; }
  .posts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 2rem; max-width: 1200px; margin: 0 auto; }
  .post-card { background: #151515; border: 1px solid #222; text-decoration: none; color: white; transition: 0.3s; display: flex; flex-direction: column; }
  .post-card:hover { transform: translateY(-10px); border-color: #d83135; }
  .card-image { height: 200px; overflow: hidden; }
  .card-image img { width: 100%; height: 100%; object-fit: cover; }
  .card-content { padding: 1.5rem; flex-grow: 1; }
  .mes-label { font-size: 0.7rem; font-weight: 800; color: #d83135; letter-spacing: 2px; text-transform: uppercase; }
  .card-content h2 { font-size: 1.5rem; margin: 0.5rem 0; text-transform: uppercase; }
  .card-content p { color: #aaa; font-size: 0.9rem; line-height: 1.5; margin-bottom: 1.5rem; }
  .read-more { font-weight: 900; font-size: 0.75rem; color: #d83135; margin-top: auto; }
</style>