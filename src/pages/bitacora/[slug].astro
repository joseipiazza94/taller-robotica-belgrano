---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

// 1. Definimos qué propiedades recibe esta página
interface Props {
  post: CollectionEntry<'bitacora'>;
}

export async function getStaticPaths() {
  const posts: CollectionEntry<'bitacora'>[] = await getCollection('bitacora');
  
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title}>
  <article class="post-detail">
    <header class="post-hero">
      {/* Portada mensual protegida */}
      <div class="hero-overlay" style={`background-image: url(${post.data.image})`}></div>
      <div class="hero-text">
        <span class="mes-badge">{post.data.mes}</span>
        <h1>{post.data.title}</h1>
      </div>
    </header>

    <div class="post-body">
      <div class="markdown-content">
        <Content />
      </div>
      
      <footer class="post-footer">
        <a href="/#bitacora" class="back-btn">← VOLVER AL INICIO</a>
        <a href="/bitacora" class="back-btn">EXPLORAR MÁS BITÁCORAS →</a>
      </footer>
    </div>
  </article>

  {/* SCRIPT INTERACTIVO: Bloquea clic derecho, pulsación larga y desactiva el arrastre nativo */}
  <script is:inline>
    const blindarMultimediaDinamico = () => {
      const multimedia = document.querySelectorAll('.post-detail img, .post-detail video');
      multimedia.forEach(el => {
        // 1. Bloquea el menú contextual (clic derecho / presión larga en táctil)
        el.addEventListener('contextmenu', e => e.preventDefault());
        
        // 2. Desactiva de raíz el arrastre nativo del elemento HTML para evitar aperturas en pestañas nuevas
        if (el.tagName.toLowerCase() === 'img') {
          el.setAttribute('draggable', 'false');
        }
      });
    };

    // Ejecuta de inmediato y maneja el comportamiento de ViewTransitions
    blindarMultimediaDinamico();
    document.addEventListener('astro:page-load', blindarMultimediaDinamico);
  </script>
</Layout>

<style>
  .post-detail { background: #0a0a0a; color: white; min-height: 100vh; }
  .post-hero { height: 50vh; position: relative; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  
  /* Bloqueamos arrastre en la portada difuminada de fondo */
  .hero-overlay { 
    position: absolute; 
    inset: 0; 
    background-size: cover; 
    background-position: center; 
    opacity: 0.3; 
    filter: blur(8px); 
    user-select: none !important;
    -webkit-user-drag: none !important;
  }
  
  .hero-text { position: relative; z-index: 10; text-align: center; }
  h1 { font-size: 4rem; font-weight: 900; text-transform: uppercase; margin-top: 1rem; }
  .mes-badge { background: #d83135; padding: 0.5rem 1rem; font-weight: 900; font-size: 0.8rem; letter-spacing: 2px; }
  .post-body { max-width: 800px; margin: 0 auto; padding: 4rem 5%; }
  
  /* --- PROTECCIÓN POR CSS DE TODO EL CONTENIDO DEL MARKDOWN --- */
  .markdown-content { font-size: 1.1rem; line-height: 1.8; color: #ccc; }
  
  .markdown-content :global(img),
  .markdown-content :global(video) {
    user-select: none !important;
    -webkit-user-drag: none !important;
    -webkit-touch-callout: none !important; /* Anula menú de guardado en iPhones */
  }

  .markdown-content :global(h2) { color: #d83135; font-size: 2rem; margin: 3rem 0 1rem; text-transform: uppercase; }
  .markdown-content :global(strong) { color: white; }
  .markdown-content :global(hr) { border: 0; height: 1px; background: #222; margin: 3rem 0; }
  
  /* FOOTER DISTRIBUIDO A LOS LADOS */
  .post-footer { 
    margin-top: 4rem; 
    border-top: 1px solid #222; 
    padding-top: 2rem; 
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .back-btn { 
    color: #d83135; 
    text-decoration: none; 
    font-weight: 900; 
    font-size: 0.8rem; 
    letter-spacing: 2px; 
    text-transform: uppercase;
    transition: opacity 0.2s ease; 
  }
  .back-btn:hover { opacity: 0.7; }

  @media (max-width: 480px) {
    .post-footer {
      flex-direction: column;
      gap: 1.5rem;
      align-items: flex-start;
    }
    h1 { font-size: 2.5rem; }
  }
</style>