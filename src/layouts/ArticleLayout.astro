---
import Navbar from '../components/Navbar.astro';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  subtitle?: string;
  heroImage?: string;
  backUrl?: string;
}

const { title, subtitle, heroImage, backUrl = "/" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title} | Taller de Robótica</title>
    <meta name="robots" content="noimageindex" />
    <ViewTransitions />
  </head>
  <body>
    <Navbar />

    <main class="article-main">
      <header class="article-hero">
        {heroImage && (
          <div class="hero-bg">
            <img src={heroImage} alt={title} />
            <div class="hero-overlay"></div>
          </div>
        )}
        
        <div class="hero-content">
          <div class="hero-text">
            <div class="hero-line"></div>
            <h1>{title}</h1>
            {subtitle && <p>{subtitle}</p>}
          </div>
          
          <a href={backUrl} class="btn-back">
            ← Volver al Inicio
          </a>
        </div>
      </header>

      <article class="article-body">
        <slot />
      </article>
    </main>

    <button class="btn-scroll-top" id="btnScrollTop" aria-label="Volver arriba">
      ↑
    </button>

    <footer class="article-footer">
      COLEGIO BELGRANO · TALLER DE ROBÓTICA
    </footer>

    <script is:inline>
      // Control de visibilidad del botón flotante según el scroll del usuario
      const handleScrollButton = () => {
        const btn = document.getElementById('btnScrollTop');
        if (!btn) return;
        
        if (window.scrollY > 300) {
          btn.classList.add('visible');
        } else {
          btn.classList.remove('visible');
        }
      };

      // Desactiva el menú contextual (clic derecho / pulsación larga) en fotos y videos
      const protegerMultimedia = () => {
        const elementos = document.querySelectorAll('.article-body img, .article-body video, .hero-bg img');
        elementos.forEach(el => {
          el.addEventListener('contextmenu', e => e.preventDefault());
        });
      };

      const setupScripts = () => {
        const btn = document.getElementById('btnScrollTop');
        if (btn) {
          btn.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
        }
        window.addEventListener('scroll', handleScrollButton);
        protegerMultimedia();
      };

      // Inicialización compatible con transiciones de página de Astro
      setupScripts();
      document.addEventListener('astro:page-load', setupScripts);
    </script>
  </body>
</html>

<style is:global>
  /* --- CUSTOM SCROLLBAR Y SELECCIÓN DE TEXTO --- */
  ::selection { background-color: #d83135; color: #ffffff; }
  ::-moz-selection { background-color: #d83135; color: #ffffff; }
  ::-webkit-scrollbar { width: 10px; }
  ::-webkit-scrollbar-track { background: #0a0a0a; border-left: 1px solid #1a1a1a; }
  ::-webkit-scrollbar-thumb { background: #333333; border-radius: 5px; transition: background 0.3s ease; }
  ::-webkit-scrollbar-thumb:hover { background: #d83135; }

  :root { color-scheme: dark; }

  body {
    margin: 0; padding: 0; background-color: #121212 !important; color: #eeeeee;
    font-family: system-ui, -apple-system, sans-serif; overflow-x: hidden;
  }
  
  /* --- BLINDAJE MULTIMEDIA CONTRA ARRASTRE Y COPIADO --- */
  img, video {
    user-select: none !important;
    -webkit-user-drag: none !important;
    -webkit-touch-callout: none !important; /* Desactiva el menú de guardado nativo en iOS (Safari/Chrome) */
  }

  .article-main { padding-top: 80px; }
  .article-hero { position: relative; width: 100%; height: 40vh; min-height: 350px; display: flex; align-items: flex-end; padding-bottom: 3rem; border-bottom: 1px solid #222; }
  .hero-bg { position: absolute; inset: 0; z-index: 0; background: #000; }
  .hero-bg img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(80%) opacity(0.3); }
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top, #121212 0%, transparent 100%); }
  .hero-content { position: relative; z-index: 10; width: 100%; max-width: 1200px; margin: 0 auto; padding: 0 5%; display: flex; justify-content: space-between; align-items: flex-end; gap: 2rem; }
  .hero-line { width: 60px; height: 4px; background-color: #d83135; margin-bottom: 1.5rem; }
  .hero-text h1 { font-size: clamp(2.5rem, 6vw, 5rem); font-weight: 900; text-transform: uppercase; color: #ffffff; margin: 0 0 0.5rem 0; line-height: 1; }
  .hero-text p { font-size: clamp(1rem, 2vw, 1.5rem); color: #aaaaaa; font-weight: 300; margin: 0; }
  .btn-back { display: inline-block; color: #d83135; border: 1px solid #d83135; padding: 0.8rem 1.5rem; text-decoration: none; font-weight: 700; text-transform: uppercase; font-size: 0.85rem; transition: all 0.3s ease; white-space: nowrap; }
  .btn-back:hover { background-color: #d83135; color: #ffffff; }

  .article-body { max-width: 800px; margin: 0 auto; padding: 5rem 5%; }
  .article-body h2 { font-size: 2.2rem; font-weight: 900; color: #ffffff; text-transform: uppercase; margin-top: 4rem; margin-bottom: 1.5rem; position: relative; padding-bottom: 1rem; }
  .article-body h2::after { content: ''; position: absolute; bottom: 0; left: 0; width: 50px; height: 2px; background-color: #d83135; }
  .article-body p { font-size: 1.15rem; line-height: 1.8; color: #cecece; margin-bottom: 1.5rem; }
  .article-body .lead { font-size: 1.6rem; font-weight: 300; color: #ffffff; line-height: 1.6; margin-bottom: 4rem; letter-spacing: 0.5px; }
  .article-body .lead strong { color: #d83135; font-weight: 700; }
  .article-body strong { color: #ffffff; font-weight: 700; }
  .article-body ul { margin-bottom: 2.5rem; padding-left: 0; list-style: none; }
  .article-body li { font-size: 1.15rem; color: #cecece; margin-bottom: 1rem; position: relative; padding-left: 1.8rem; }
  .article-body li::before { content: '→'; position: absolute; left: 0; color: #d83135; font-weight: 900; }
  .article-body img { width: 100%; height: auto; border: 1px solid #333; margin: 3rem 0; filter: grayscale(20%); transition: filter 0.4s ease; }
  .article-body img:hover { filter: grayscale(0%); }
  
  /* ESTILOS DEL BOTÓN INTERACTIVO DE RETORNO (Apagado por defecto en PC) */
  .btn-scroll-top {
    display: none;
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background-color: #252525;
    color: #ffffff;
    border: 1px solid #444;
    width: 50px;
    height: 50px;
    border-radius: 4px;
    font-size: 1.2rem;
    font-weight: bold;
    cursor: pointer;
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(0,0,0,0.5);
  }

  .btn-scroll-top.visible {
    opacity: 1;
    visibility: visible;
  }

  .btn-scroll-top:hover {
    background-color: #d83135;
    border-color: #d83135;
  }

  .article-footer { border-top: 1px solid #222; padding: 2rem 0; text-align: center; color: #666; font-size: 0.85rem; letter-spacing: 3px; margin-top: 4rem; }

  /* MÓVIL: Activación del botón flotante */
  @media (max-width: 1024px) {
    .btn-scroll-top {
      display: block;
    }
  }

  @media (max-width: 768px) {
    .hero-content { flex-direction: column; align-items: flex-start; }
    .btn-back { align-self: flex-start; }
    .btn-scroll-top { bottom: 1.5rem; right: 1.5rem; width: 45px; height: 45px; }
  }
</style>